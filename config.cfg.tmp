# GNSS_Traccar 配置文件 (EC800M)
# 每行格式: key=value ，# 开头为注释

# Traccar 服务器 留空则不发送Traccar
traccar_host=traccar_report.ctsdn.com
# Traccar 端口（OSM 协议常用 5055）
traccar_port=2232

# 运动时上报间隔（秒）
moving_interval=1
# 静止时上报间隔（秒）
still_interval=120
# 速度阈值（km/h），超过则视为运动
still_speed_threshold=1

# APRS 配置 callsign留空则不发送APRS
aprs_callsign=BI1FQO
aprs_ssid=BI1FQO-QU
aprs_message=EC800M-APRS
aprs_icon=>
aprs_passcode=20898
aprs_host=china.aprs2.net
aprs_port=14580
#最小间隔30秒
aprs_interval=60

# 持久化缓存文件路径（弱网时未发送的位置会写入此文件）
cache_file=/usr/traccar_cache.txt

# 刷机控制 GPIO 编号。该引脚未悬空（如接 GND）时程序退出，便于进入刷机模式。请查阅 EC800M 硬件手册确认可用 GPIO
flash_gpio=76

# 网络就绪等待超时（秒）
network_timeout=60
# HTTP 请求超时（秒）
http_timeout=10
# 发送失败后重试退避上限（秒）
max_backoff=60

# 看门狗超时（秒），超时未喂狗则重启；0 表示不启用
wdt_period=60

# LBS 基站定位参数（lbs_test.py 使用；仅部分模组支持 cellLocator）
lbs_token=5Fv*********vs
lbs_server=www.queclocator.com
lbs_port=80
lbs_profile_idx=1
lbs_timeout=30
# 两次 LBS 请求最小间隔（秒），默认 60；仅无 GNSS 时按此间隔请求
lbs_interval=60
# 超时 1~300 秒，不填默认 30
# lbs_timeout=30
# PDP 上下文 1~3，不填用当前拨号
# lbs_profile_idx=1
