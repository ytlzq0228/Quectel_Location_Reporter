# GNSS Reporter 配置文件示例 (EC800M)
# 复制为 config.cfg 后按需修改；请勿将含真实 token 的 config.cfg 提交到仓库
# 每行格式: key=value ，# 开头为注释

# Traccar 服务器 留空则不发送Traccar
traccar_host=traccar.example.com
# Traccar 端口（OSM 协议常用 5055）
traccar_port=5055

# 运动时上报间隔（秒）
moving_interval=10
# 静止时上报间隔（秒）
still_interval=300
# 速度阈值（km/h），超过则视为运动
still_speed_threshold=5
# 静止距离阈值（米），低速但自上次上报移动距离超过该值则强制上报；0 表示关闭
distance_threshold=5

# APRS 配置 callsign留空则不发送APRS
aprs_callsign=
aprs_ssid=
aprs_message=
aprs_icon=>
aprs_passcode=
aprs_host=rotate.aprs.net
aprs_port=14580
# 最小间隔30秒
aprs_interval=60

# 刷机控制 GPIO 编号。该引脚未悬空（如接 GND）时程序退出，便于进入刷机模式。请查阅 EC800M 硬件手册确认可用 GPIO
flash_gpio=-1

# 网络就绪等待超时（秒）
network_check_timeout=10
# HTTP 请求超时（秒）
http_timeout=10
# 发送失败后重试退避上限（秒）
max_backoff=60

# 看门狗超时（秒），超时未喂狗则重启；0 表示不启用
wdt_period=60
# 屏幕亮度 1–100，实际生效 1–100（百分比）；不存在或 0 时默认 100
brightness=100
# 非 0：电源键动作→主循环→OLED 刷新返回 分段耗时（日志前缀 PKchain）；须在设备 /usr/config.cfg 取消注释并设为 1
#powerkey_chain_debug=0

# OLED：ssd1306（默认 I2C 128x64）或 ssd1327（SPI 128x128）
#oled_type=ssd1306
#oled_spi_port=0
#oled_spi_mode=0
#oled_spi_clk=4  #0:812.5kHz 1:1.625MHz 2:3.25MHz 3:6.5MHz 4:13MHz
#oled_spi_group=1
#oled_gpio_rst=5
#oled_gpio_dc=7
#oled_gpio_cs=8
# SSD1327 外部 VPP(12V) 升压使能（高=开），与模组逻辑供电无关；默认 GPIO20；-1 表示不控制
#oled_boost_gpio=20
#oled_ssd1327_remap=0x51
#oled_function_sel_a=0
# 非 0：SSD1327 汇总一行：prepare_ms=构图/写显存（ticks_ms）；spi_wall/fb_*=送屏（ticks_us）
#oled_spi_timing_debug=0
# 非 0：每条 spi.write 打一行（UART 很慢，会把 total 撑到几十 ms，一般勿开）
#oled_spi_timing_verbose=0
# 非 0：SSD1327 update_display 内 prepare 分段（head_ms / fill_u_ms / wake / …），与 oled_spi_timing_debug 配合看构图 vs 送屏
#oled_prepare_debug=0

# LBS 基站定位参数（lbs_test.py 使用；仅部分模组支持 cellLocator）
#申请移远LBS token https://portal.iotomp.com/locator_token.html
lbs_token=5Fv*********vs
lbs_server=www.queclocator.com
lbs_port=80
lbs_profile_idx=1
lbs_timeout=30
# 两次 LBS 请求最小间隔（秒），默认 60；仅无 GNSS 时按此间隔请求
lbs_interval=60
# 超时 1~300 秒，不填默认 30
# lbs_timeout=30
# PDP 上下文 1~3，不填用当前拨号
# lbs_profile_idx=1